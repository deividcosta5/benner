@model IEnumerable<DigitalMicrowave.Business.Models.HeatingProgram>
@{
    ViewData["Title"] = "Programas";
}

<h4 class="mb-3">📋 Programas de Aquecimento</h4>

<div class="d-flex justify-content-end mb-3">
    <a asp-action="Create" class="btn btn-warning">+ Novo Programa</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Nome</th>
                <th>Alimento</th>
                <th>Tempo</th>
                <th>Potência</th>
                <th>Char</th>
                <th>Instruções</th>
                <th>Tipo</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td class="@(p.IsCustom ? "fst-italic" : "fw-semibold")">@p.Name</td>
                    <td>@p.Food</td>
                    <td>@(p.TimeInSeconds / 60)min @(p.TimeInSeconds % 60 > 0 ? $"{p.TimeInSeconds % 60}s" : "")</td>
                    <td>@p.Power</td>
                    <td><code>'@p.HeatingChar'</code></td>
                    <td><small class="text-muted">@(p.Instructions ?? "-")</small></td>
                    <td>
                        @if (p.IsCustom)
                        {
                            <span class="badge bg-warning text-dark">Custom</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Pré-definido</span>
                        }
                    </td>
                    <td>
                        @if (p.IsCustom)
                        {
                            <form asp-action="Delete" method="post"
                                  onsubmit="return confirm('Excluir o programa \'@p.Name\'?')">
                                <input type="hidden" name="id" value="@p.Id" />
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">🗑</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
